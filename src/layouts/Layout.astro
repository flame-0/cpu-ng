---
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { settings } from '../lib/settings';
import { ClientRouter } from 'astro:transitions';

export interface Props {
    title?: string;
    description?: string;
    image?: string;
    ogType?: 'website' | 'article';
    canonicalURL?: string;
    publishedDate?: string;
}

const {
    title,
    description,
    image,
    ogType = 'website',
    canonicalURL,
    publishedDate,
} = Astro.props;

const siteTitle = settings.site_title;
const fullTitle = title ? `${title} - ${siteTitle}` : siteTitle;
const desc = description || settings.tagline;
const siteUrl = Astro.site?.origin || 'http://localhost:4321';
const url = canonicalURL ? new URL(canonicalURL, siteUrl).href : Astro.url.href;
const ogImage = image ? new URL(image, siteUrl).href : `${siteUrl}/images/og-default.png`;

const jsonLd = {
    '@context': 'https://schema.org',
    '@type': ogType === 'article' ? 'Article' : 'Organization',
    ...(ogType === 'article'
        ? { headline: title, description: desc, ...(publishedDate && { datePublished: publishedDate }), ...(image && { image: ogImage }) }
        : { name: siteTitle, description: settings.tagline, url: siteUrl }),
};
---

<!doctype html>
<html lang="en-PH">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="shortcut icon" href="/favicon.ico" />
        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
        <link rel="manifest" href="/site.webmanifest" />
        <ClientRouter />
        <meta name="description" content={desc} />
        <meta name="theme-color" content="#0d0d0d" />

        <title>{fullTitle}</title>

        <meta property="og:title" content={fullTitle} />
        <meta property="og:description" content={desc} />
        <meta property="og:type" content={ogType} />
        <meta property="og:url" content={url} />
        <meta property="og:site_name" content={siteTitle} />
        <meta property="og:locale" content="en_PH" />
        {ogImage && <meta property="og:image" content={ogImage} />}

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={fullTitle} />
        <meta name="twitter:description" content={desc} />
        {ogImage && <meta name="twitter:image" content={ogImage} />}

        <link rel="alternate" type="application/rss+xml" title={`${siteTitle} RSS`} href="/rss.xml" />

        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>

        {import.meta.env.PUBLIC_UMAMI_SCRIPT_URL && import.meta.env.PUBLIC_UMAMI_WEBSITE_ID && (
            <script async src={import.meta.env.PUBLIC_UMAMI_SCRIPT_URL} data-website-id={import.meta.env.PUBLIC_UMAMI_WEBSITE_ID}></script>
        )}
    </head>

    <body class="min-h-screen bg-(--bg) text-(--fg) antialiased">
        <Header />
        <main>
            <slot />
        </main>
        <Footer />
    </body>
</html>
