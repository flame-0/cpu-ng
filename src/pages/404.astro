---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page not found">
    <div class="flex min-h-[70vh] items-center justify-center px-4 pt-28">
        <div class="max-w-md text-center">
            <h1 class="text-5xl font-bold text-(--fg-muted)">404</h1>
            <p class="mt-4 text-(--fg-secondary) leading-relaxed">
                This page does not exist or has been moved.
            </p>
            <div class="mt-8">
                <a href="/" class="text-sm font-medium text-(--accent) hover:text-(--accent-hover) transition-colors">&larr; Back to home</a>
            </div>
        </div>
    </div>
</Layout>
