---
import Layout from '../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

const pages = await getCollection('pages');
const page = pages.find(p => p.id === 'terms');
if (!page) throw new Error('Terms page not found');
const { Content } = await render(page);
---

<Layout title={page.data.title}>
    <div class="mx-auto max-w-3xl px-4 pt-28 pb-16 sm:px-6">
        <h1 class="text-3xl font-bold">{page.data.title}</h1>
        <div class="prose prose-lg mt-8 max-w-none"><Content /></div>
    </div>
</Layout>
