---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { Badge } from '../../components/ui/badge';
import { slugify } from '../../lib/slug';

export async function getStaticPaths() {
    const posts = await getCollection('posts');
    return posts.filter(p => p.data.published).map(post => ({ params: { slug: post.data.slug || slugify(post.data.title) }, props: { post } }));
}

const { post } = Astro.props;
const { title, date, excerpt, categories, tags, author, featured_image } = post.data;
const { Content } = await render(post);
const wordCount = ((post as any).body || '').split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));
---

<Layout title={title} description={excerpt || undefined} ogType="article" publishedDate={date.toISOString()} image={featured_image || undefined}>
    <article class="mx-auto max-w-3xl px-4 pt-28 pb-16 sm:px-6">
        <header class="mb-10">
            <div class="mb-3 flex flex-wrap gap-2">
                {categories.map(cat => <a href={`/category/${slugify(cat)}`}><Badge variant="default">{cat}</Badge></a>)}
            </div>
            <h1 class="text-3xl font-bold leading-tight sm:text-4xl">{title}</h1>
            <div class="mt-4 flex flex-wrap items-center gap-2 text-sm text-(--fg-muted)">
                <a href={`/author/${slugify(author)}`} class="font-semibold text-(--fg) hover:text-(--accent) transition-colors">{author}</a>
                <span>&middot;</span>
                <time datetime={date.toISOString()}>{date.toLocaleDateString('en-PH', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
                <span>&middot;</span>
                <span>{readingTime} min read</span>
            </div>
            {tags.length > 0 && <div class="mt-3 flex flex-wrap gap-1.5">{tags.map(tag => <a href={`/tag/${slugify(tag)}`} class="text-xs text-(--fg-muted) hover:text-(--accent) transition-colors">#{tag}</a>)}</div>}
        </header>
        {featured_image && (
            <img src={featured_image} alt={title} class="w-full border border-(--border) mb-10" />
        )}
        <div class="prose prose-lg max-w-none"><Content /></div>
        <div class="mt-16 border-t border-(--border-light) pt-8">
            <a href="/posts/" class="text-sm font-medium text-(--accent) hover:text-(--accent-hover) transition-colors">&larr; Back to all posts</a>
        </div>
    </article>
</Layout>
