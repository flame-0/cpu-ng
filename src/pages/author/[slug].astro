---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { slugify } from '../../lib/slug';
import PostCard from '../../components/posts/PostCard.astro';

export async function getStaticPaths() {
    const posts = await getCollection('posts');
    const published = posts.filter(p => p.data.published);
    const authors = new Map<string, { slug: string; name: string }>();
    for (const p of published) {
        const name = p.data.author;
        const slug = slugify(name);
        if (!authors.has(slug)) authors.set(slug, { slug, name });
    }
    return [...authors.values()].map(author => ({
        params: { slug: author.slug },
        props: { name: author.name, posts: published.filter(p => slugify(p.data.author) === author.slug) },
    }));
}

const { name, posts } = Astro.props;
---

<Layout title={`Author: ${name}`} description={`Posts by ${name}.`}>
    <div class="mx-auto max-w-4xl px-4 pt-28 pb-16 sm:px-6">
        <h1 class="text-3xl font-bold">{name}</h1>
        <p class="mt-2 text-(--fg-secondary)">{posts.length} {posts.length === 1 ? 'post' : 'posts'} by this author</p>
        <div class="mt-10 space-y-6">{posts.map(post => <PostCard post={post} />)}</div>
        <div class="mt-12 border-t border-(--border-light) pt-8">
            <a href="/posts/" class="text-sm font-medium text-(--accent) hover:text-(--accent-hover) transition-colors">&larr; All posts</a>
        </div>
    </div>
</Layout>
