---
import CpuLogo from '../shared/CpuLogo.astro';
import SearchDialog from '../islands/SearchDialog';

const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';
---

<header class="fixed top-4 left-1/2 z-40 -translate-x-1/2 md:w-[95%] md:max-w-2xl">
    <nav class:list={[
        'flex items-center rounded-full border border-(--border) bg-(--bg-elevated)/85 backdrop-blur-md pr-3 py-2 shadow-lg gap-8',
        isHome ? 'pl-3 md:pl-4' : 'pl-4',
        isHome ? 'justify-end md:justify-between' : 'justify-between',
    ]} aria-label="Main">
        <a href="/" class:list={[
            'flex items-center gap-2 text-(--fg) transition-opacity hover:opacity-80 min-w-0',
            isHome ? 'hidden md:flex' : '',
        ]} aria-label="CPU Home">
            {isHome ? (
                <svg width="32" height="32" viewBox="0 0 185 185" aria-hidden="true"><rect width="185" height="185" fill="none" /></svg>
            ) : (
                <CpuLogo size={32} />
            )}
            {!isHome && (
                <span class="text-sm font-semibold tracking-tight truncate md:hidden">
                    <span class="hidden [@media(min-width:420px)]:inline">Computer Professionals&rsquo; Union</span>
                    <span class="[@media(min-width:420px)]:hidden">CPU</span>
                </span>
            )}
        </a>

        <div class="hidden items-center gap-1 md:flex">
            <a href="/" class:list={[
                'px-3 py-1.5 text-sm transition-colors',
                isHome ? 'text-(--fg) nav-active' : 'text-(--fg-secondary) hover:text-(--fg)',
            ]}>Home</a>
            <a href="/posts/" class:list={[
                'px-3 py-1.5 text-sm transition-colors',
                currentPath.startsWith('/posts') ? 'text-(--fg) nav-active' : 'text-(--fg-secondary) hover:text-(--fg)',
            ]}>Posts</a>
            <a href="/about" class:list={[
                'px-3 py-1.5 text-sm transition-colors',
                currentPath === '/about' ? 'text-(--fg) nav-active' : 'text-(--fg-secondary) hover:text-(--fg)',
            ]}>About</a>
            <a href="/contact" class:list={[
                'px-3 py-1.5 text-sm transition-colors',
                currentPath === '/contact' ? 'text-(--fg) nav-active' : 'text-(--fg-secondary) hover:text-(--fg)',
            ]}>Contact</a>
        </div>

        <div class="flex items-center gap-1">
            <SearchDialog client:load />
            <button id="mobile-menu-btn" class="inline-flex items-center justify-center p-2 text-(--fg-secondary) hover:text-(--fg) md:hidden transition-colors" aria-label="Menu">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="4" x2="20" y1="6" y2="6" /><line x1="4" x2="20" y1="12" y2="12" /><line x1="4" x2="20" y1="18" y2="18" />
                </svg>
            </button>
        </div>
    </nav>

    <div id="mobile-menu" class="mt-2 rounded-2xl border border-(--border) bg-(--bg-elevated)/85 backdrop-blur-md px-2 py-2 shadow-lg md:hidden transition-all duration-200 ease-out opacity-0 pointer-events-none">
        <a href="/" class="block rounded-xl px-3 py-2 text-sm text-(--fg-secondary) hover:bg-(--bg-surface) hover:text-(--fg) transition-colors">Home</a>
        <a href="/posts/" class="block rounded-xl px-3 py-2 text-sm text-(--fg-secondary) hover:bg-(--bg-surface) hover:text-(--fg) transition-colors">Posts</a>
        <a href="/about" class="block rounded-xl px-3 py-2 text-sm text-(--fg-secondary) hover:bg-(--bg-surface) hover:text-(--fg) transition-colors">About</a>
        <a href="/contact" class="block rounded-xl px-3 py-2 text-sm text-(--fg-secondary) hover:bg-(--bg-surface) hover:text-(--fg) transition-colors">Contact</a>
    </div>
</header>

<script>
    function setupMenu() {
        const btn = document.getElementById('mobile-menu-btn');
        const menu = document.getElementById('mobile-menu');
        if (!btn || !menu) return;
        const clone = btn.cloneNode(true) as HTMLElement;
        btn.parentNode?.replaceChild(clone, btn);
        clone.addEventListener('click', () => menu.classList.toggle('open'));
    }
    document.addEventListener('astro:page-load', setupMenu);
    setupMenu();
</script>
