---
import { settings } from '../../lib/settings';
---

<footer class="border-t border-(--border-light) bg-(--bg-elevated)">
    <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6">
        <div class="grid gap-10 sm:grid-cols-3">
            <div>
                <h4 class="text-lg font-extrabold text-(--fg)">{settings.site_title}</h4>
                <p class="mt-2 text-sm leading-relaxed text-(--fg-secondary)">{settings.tagline}</p>
            </div>
            <div>
                <h4 class="text-base font-bold text-(--fg)">Pages</h4>
                <ul class="mt-2 space-y-1.5">
                    <li><a href="/" class="text-sm text-(--fg-secondary) hover:text-(--accent) transition-colors">Home</a></li>
                    <li><a href="/posts/" class="text-sm text-(--fg-secondary) hover:text-(--accent) transition-colors">Posts</a></li>
                    <li><a href="/about" class="text-sm text-(--fg-secondary) hover:text-(--accent) transition-colors">About</a></li>
                    <li><a href="/contact" class="text-sm text-(--fg-secondary) hover:text-(--accent) transition-colors">Contact</a></li>
                    <li><a href="/privacy" class="text-sm text-(--fg-secondary) hover:text-(--accent) transition-colors">Privacy</a></li>
                    <li><a href="/terms" class="text-sm text-(--fg-secondary) hover:text-(--accent) transition-colors">Terms</a></li>
                </ul>
            </div>
            <div>
                <h4 class="text-base font-bold text-(--fg)">Connect</h4>
                <ul class="mt-2 space-y-1.5">
                    {settings.social_links.twitter && (<li><a href={settings.social_links.twitter} target="_blank" rel="noopener noreferrer" class="text-sm text-(--fg-secondary) hover:text-(--accent) transition-colors">Twitter</a></li>)}
                    {settings.social_links.facebook && (<li><a href={settings.social_links.facebook} target="_blank" rel="noopener noreferrer" class="text-sm text-(--fg-secondary) hover:text-(--accent) transition-colors">Facebook</a></li>)}
                    {settings.social_links.email && (<li><a href={`mailto:${settings.social_links.email}`} class="text-sm text-(--fg-secondary) hover:text-(--accent) transition-colors">{settings.social_links.email}</a></li>)}
                </ul>
            </div>
        </div>
        <div class="mt-10 border-t border-(--border-light) pt-6 text-center text-xs text-(--fg-muted)">
            &copy; {new Date().getFullYear()} {settings.site_title}
        </div>
    </div>
</footer>
