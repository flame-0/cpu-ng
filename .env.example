# public environment variables - safe to commit
# copy to .env and fill in values for local dev or deployment

# umami analytics - self-hosted instance script url
# get this from your umami dashboard under settings > websites > tracking code
PUBLIC_UMAMI_SCRIPT_URL=
PUBLIC_UMAMI_WEBSITE_ID=

# site url for rss feed, sitemap, and canonical links
PUBLIC_SITE_URL=http://localhost:4321
